{
  "name": "cselectives-api",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "lint": "eslint -c eslint.config.mjs \"src/**/*.{js,ts,tsx}\" --quiet --fix",
    "format": "prettier '**/*.ts' --write",
    "build": "tsc",
    "start": "npx prisma migrate deploy && node dist/src/index.js",
    "dev": "NODE_ENV=dev tsx src/index.ts",
    "dev:watch": "NODE_ENV=dev tsx watch src/index.ts",
    "test": "jest --coverage --verbose"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@types/jest": "30.0.0",
    "cors": "2.8.6",
    "envsafe": "2.0.3",
    "express": "5.2.1",
    "ioredis": "5.10.1",
    "jsonwebtoken": "9.0.3",
    "node-fetch": "3.3.2",
    "pg": "8.20.0",
    "reflect-metadata": "0.2.2",
    "swagger-ui-express": "5.0.1",
    "winston": "3.19.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "^24.12.0",
    "@types/swagger-ui-express": "4.1.8",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "17.4.0",
    "jest": "30.3.0",
    "prettier": "3.8.1",
    "prisma": "5.22.0",
    "ts-jest": "29.4.6",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.1"
  }
}
